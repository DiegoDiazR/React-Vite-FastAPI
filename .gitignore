# Configuración de Seguridad y Exclusiones para CoreRisk

# --- Sensitive Files & Environments ---
.env
.env.*
!.env.example
*.pem
*.key
secrets.txt

# --- Backups & Local Versions ---
backend1/
backend_backup/
*.bak
*.swp

# --- Databases ---
# Ignoramos la base de datos local para evitar subir datos sensibles o archivos pesados
*.db
*.sqlite3
/backend/rbi_system.db

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Node / React ---
node_modules/
/frontend/dist/
/frontend/build/
.eslintcache
.stylelintcache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDEs & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Project Specific ---
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
